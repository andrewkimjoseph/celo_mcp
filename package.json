{
  "name": "@andrewkimjoseph/celina-mcp",
  "version": "0.7.13",
  "description": "Celina — MCP server for Celo mainnet. Balances, transfers, Self Agent ID, and chain reads for LLM agents.",
  "type": "module",
  "main": "build/index.js",
  "exports": {
    ".": {
      "import": "./build/index.js",
      "types": "./build/index.d.ts"
    },
    "./server": {
      "import": "./build/server/create-server.js",
      "types": "./build/server/create-server.d.ts"
    }
  },
  "bin": {
    "celina-mcp": "bin/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "build/",
    "bin/",
    "assets/logo.png",
    "assets/logo-black.png",
    "assets/logo-yellow.png",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf build && tsc -p tsconfig.build.json",
    "start": "node build/index.js",
    "dev": "tsc --watch",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "prepare": "npm run build",
    "inspect": "npx @modelcontextprotocol/inspector node build/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "celina-mcp",
    "celina",
    "celo",
    "blockchain",
    "web3",
    "ai",
    "agent"
  ],
  "author": "Andrew Kim Joseph",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewkimjoseph/celina-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/andrewkimjoseph/celina-mcp/issues"
  },
  "homepage": "https://github.com/andrewkimjoseph/celina-mcp#readme",
  "dependencies": {
    "@andrewkimjoseph/celina-sdk": "^0.2.12",
    "@modelcontextprotocol/sdk": "^1.22.0",
    "@noble/ed25519": "^3.1.0",
    "dotenv": "^17.4.2",
    "viem": "^2.39.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
