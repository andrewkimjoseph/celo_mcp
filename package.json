{
  "name": "@andrewkimjoseph/celina",
  "version": "0.3.5",
  "description": "Celina — MCP server for Celo mainnet. Balances, transfers, Self Agent ID, and chain reads for LLM agents.",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "celina": "bin/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "build/",
    "bin/",
    "assets/logo.png",
    "assets/logo-black.png",
    "assets/logo-yellow.png",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf build && tsc",
    "start": "node build/index.js",
    "start:http": "node build/http.js",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "inspect": "npx @modelcontextprotocol/inspector node build/index.js",
    "encrypt-key": "tsx scripts/encrypt-key.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "celina",
    "celo",
    "blockchain",
    "web3",
    "ai",
    "agent"
  ],
  "author": "Andrew Kim Joseph",
  "license": "MIT",
  "dependencies": {
    "@mento-protocol/mento-sdk": "^3.2.8",
    "@modelcontextprotocol/sdk": "^1.22.0",
    "@noble/ed25519": "^3.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "viem": "^2.39.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.8.2"
  }
}
