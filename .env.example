# CELO_RPC_URL_MAINNET=https://forno.celo.org

# Local stdio mode — plain private key for write tools
# CELO_PRIVATE_KEY=0x...

# Self Agent ID — separate from CELO wallet (signing, identity, refresh, deregister)
# SELF_AGENT_PRIVATE_KEY=0x...
# SELF_AGENT_API_BASE=https://app.ai.self.xyz

# HTTP mode — RSA key pair for encrypting user private keys per request
# Generate with:
#   openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -pubout -in private.pem -out public.pem
# WALLET_ENCRYPTION_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# HTTP server port (Render sets PORT automatically)
# PORT=10000

# Comma-separated custom domains allowed alongside RENDER_EXTERNAL_HOSTNAME
# ALLOWED_HOSTS=mcp.celina.andrewkimjoseph.com
